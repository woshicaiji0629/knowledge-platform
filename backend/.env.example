APP_NAME=knowledge-platform
APP_ENV=local
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Aliyun customer service integration.
# Fill these after confirming the exact Aliyun product and API contract.
ALIYUN_CUSTOMER_SERVICE_ENDPOINT=
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_CUSTOMER_SERVICE_INSTANCE_ID=

# RAG retrieval and answer generation.
# Use "qdrant" after indexing docs into the local Qdrant collection.
VECTOR_STORE_PROVIDER=memory
QDRANT_ENDPOINT=http://localhost:6333
QDRANT_COLLECTION=aliyun_docs_product_v1
RETRIEVAL_TOP_K=5
RETRIEVAL_CONTEXT_MAX_CHARS=6000

# Use "dashscope" only when you want paid text generation.
ANSWER_GENERATOR_PROVIDER=skeleton
DASHSCOPE_API_KEY=
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
DASHSCOPE_CHAT_MODEL=qwen-turbo
